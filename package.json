{
  "name": "rawaj",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:admin": "npm run dev --workspace=apps/admin",
    "dev:scanner": "npm run dev --workspace=apps/scanner",
    "worker:delivery": "npm run worker:delivery --workspace=apps/api",
    "dev:raw": "concurrently \"npm run dev:api\" \"npm run dev:admin\" \"npm run dev:scanner\"",
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1",
    "migrate": "npm run migrate --workspace=apps/api",
    "seed": "npm run seed --workspace=apps/api"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "expo": "^53.0.0",
    "metro": "^0.82.5",
    "metro-config": "^0.82.5",
    "metro-resolver": "^0.82.5"
  },
  "overrides": {
    "react": "19.0.0",
    "react-native": "0.79.6"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
